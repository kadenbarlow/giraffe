{
  "name": "@kadenbarlow/giraffe",
  "description": "A terminal based GraphQL client",
  "author": "Kaden Barlow <kadenbarlow@gmail.com> (https://kadenbarlow.dev)",
  "version": "0.2.1",
  "license": "GPLv3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kadenbarlow/giraffe.git"
  },
  "keywords": [
    "tui",
    "cli",
    "graphql",
    "graphql-client"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "giraffe": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:sea:blob": "npm run build && node ./scripts/build-sea-entry.mjs && node --experimental-sea-config sea-config.json",
    "build:sea": "npm run build:sea:blob && node ./scripts/build-sea.mjs",
    "dev": "npm run build && node --inspect=9230 ./dist/cli/index.js",
    "start": "npm run build && node ./dist/cli/index.js",
    "lint": "prettier --check src/. && eslint src/.",
    "prepare": "husky",
    "release": "node ./scripts/publish.mjs",
    "release:npm": "npm run build && npm publish",
    "release:homebrew": "npm run build:sea && HOMEBREW_TAP_REPO_PATH=../homebrew-tap node ./scripts/publish-homebrew.mjs"
  },
  "dependencies": {
    "clipboardy": "^4.0.0",
    "graphql": "^16.9.0",
    "graphql-tools": "^9.0.2",
    "highlight.js": "^11.10.0",
    "ink": "^7.0.1",
    "meow": "^11.0.0",
    "parse5": "^5.0.1",
    "parse5-htmlparser2-tree-adapter": "^5.0.1",
    "prettier": "^3.3.3",
    "react": "^19.2.5",
    "tree-sitter": "^0.21.1",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/react": "^19.2.14",
    "chalk": "^5.2.0",
    "esbuild": "^0.25.11",
    "eslint-config-xo-react": "^0.27.0",
    "eslint-plugin-perfectionist": "^3.6.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postject": "^1.0.0-alpha.6"
  }
}
